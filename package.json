{
  "name": "swimtrack",
  "version": "0.1.0",
  "private": true,
  "description": "Prototipo academico para conectar entrenadores de natacion con usuarios.",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:frontend": "npm run dev --workspace frontend",
    "dev:backend": "npm run dev --workspace backend",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspaces",
    "test:unit": "npm run test:unit --workspaces",
    "test:coverage": "npm run test:coverage --workspaces",
    "test:integration": "npm run test:integration --workspace backend",
    "test:e2e": "node scripts/run-e2e-dev.mjs",
    "test:e2e:docker": "node scripts/run-e2e-docker.mjs",
    "test:e2e:headed": "playwright test --headed",
    "format": "npm run format --workspaces"
  },
  "devDependencies": {
    "@openai/codex": "^0.128.0",
    "@playwright/test": "^1.60.0"
  }
}
